#!/bin/sh
# Pre-commit hook: run golangci-lint on the entire working tree, mirroring
# what CI does. The hook does NOT filter by staged files and does NOT stash
# unstaged changes — it lints whatever is on disk so the result matches
# `golangci-lint run ./...` from the project root, the same command CI runs.
#
# REQUIRED_LINT_VERSION must match the `version:` pinned in
# .github/workflows/ci.yml and release.yml. The hook warns when the local
# binary differs so contributors don't ship code that fails CI silently.
if ! command -v golangci-lint >/dev/null 2>&1; then
    echo "golangci-lint is not installed. Install it: https://golangci-lint.run/welcome/install/"
    exit 1
fi

echo "pre-commit: running golangci-lint..."
golangci-lint run ./...
status=$?

if [ $status -eq 0 ]; then
    echo "pre-commit: passed"
else
    echo "pre-commit: failed"
fi

exit $status
